<?xml version="1.0" ?>
<GenRoBag>
	<db dbname="gedi" implementation="sqlite"/>

	<packages>
		<cogen pkgcode='gedi:cogen' />
		<gnrcore_sys pkgcode='gnrcore:sys' />
		<gnrcore_adm pkgcode='gnrcore:adm' />
	</packages>

	<authentication pkg="adm">
		<py_auth defaultTags="user" method="authenticate" pkg="adm"/>
	</authentication>
</GenRoBag>
